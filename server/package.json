{
    "name": "@lore-builder/server",
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "clean": "rm -rf ./dist",
        "setup": "bb-path-alias ./src/setup.ts",
        "start": "bb-path-alias ./src/index.ts",
        "build": "npm run clean && swc ./src -d ./dist",
        "check": "tsc -p ./tsconfig.json --noEmit",
        "nodemon": "nodemon ./src/index.ts"
    },
    "devDependencies": {
        "@swc/cli": "^0.1.62",
        "@swc/core": "^1.3.95",
        "@types/express": "^4.17.20",
        "@types/node": "^20.8.9",
        "ava": "^5.3.1",
        "nodemon": "^3.0.1",
        "ts-node": "^10.9.1",
        "typescript": "^5.2.2"
    },
    "dependencies": {
        "@bleed-believer/commander": "^0.11.0",
        "@bleed-believer/espresso": "^0.11.0",
        "@bleed-believer/path-alias": "^0.15.2",
        "express": "^4.18.2",
        "sqlite3": "^5.1.6",
        "typeorm": "^0.3.17"
    }
}
